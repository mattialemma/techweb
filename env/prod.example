DEBUG=False
ALLOWED_HOSTS=example.com,www.example.com

VITE_API_BASE_URL=/api
HTTP_PORT=80

AUTH_REFRESH_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

AVATAR_MAX_UPLOAD_SIZE=2097152
AVATAR_MAX_DIMENSION=1024
AVATAR_ALLOWED_FORMATS=JPEG,PNG,WEBP
DATA_UPLOAD_MAX_MEMORY_SIZE=3145728
FILE_UPLOAD_MAX_MEMORY_SIZE=3145728
CHALLENGE_REGEX_TIMEOUT_SECONDS=0.05

THROTTLE_LOGIN_RATE=20/min
THROTTLE_TOKEN_REFRESH_RATE=60/min
THROTTLE_LOGOUT_RATE=60/min
THROTTLE_PASSWORD_RESET_REQUEST_RATE=10/hour
THROTTLE_PASSWORD_RESET_VERIFY_RATE=30/min
THROTTLE_PASSWORD_RESET_APPLY_RATE=10/min

EMAIL_PROVIDER=brevo
BREVO_API_KEY=replace-with-brevo-api-key
BREVO_OTP_TEMPLATE_ID=replace-with-template-id
